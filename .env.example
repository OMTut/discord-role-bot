# Discord Bot Configuration
DISCORD_TOKEN=your_bot_token_here
ENVIRONMENT=development

# Development Server
DEV_GUILD_ID=server_id_for_development

# Production Server
PROD_GUILD_ID=server_id_for_production

# ORG Admin integration
ORG_ADMIN_URL=http://localhost:8002
BOT_API_KEY=your_api_key_here

# API server
API_HOST=0.0.0.0
API_PORT=8001

# Bot Settings
COMMAND_PREFIX=!
LOG_LEVEL=INFO
